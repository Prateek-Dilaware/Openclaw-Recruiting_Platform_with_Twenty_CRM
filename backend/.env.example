# ─── Openclaw Recruiting Platform — Backend Environment Template ─────────────
#
# Copy this file to backend/.env and fill in the values.
# This file is loaded by app/settings.py via python-dotenv and pydantic-settings.
#
# NEVER commit the real backend/.env with secrets to git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application Settings ────────────────────────────────────────────────────
APP_NAME="Openclaw Recruiting Platform"
APP_ENV=development
DEBUG=true

# Security key used by the FastAPI backend for signing / internal secrets.
SECRET_KEY=your-super-secret-key-change-in-production

# ─── Twenty CRM Integration ──────────────────────────────────────────────────
# API key generated inside Twenty CRM (Settings → API & Webhooks).
TWENTY_API_KEY=your-twenty-api-key

# Base URL for the Twenty CRM API.
# Inside docker-compose.dev.yml this is overridden to http://twenty-server:3000
# so the backend container can reach Twenty on the internal network.
TWENTY_API_URL=http://localhost:3000

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Selects which LLM backend to use. Supported values:
#   gemini | openai | openrouter | openclaw | mock
LLM_PROVIDER=openrouter

# Provider-specific keys. Only the one matching LLM_PROVIDER is required.
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Used only when LLM_PROVIDER=openclaw.
OPENCLAW_URL=

# ─── ElevenLabs (Voice / Conversational AI) ──────────────────────────────────
# Leave empty to run the ElevenLabs service in Mock Mode.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# ─── Optional: Local Database URL ────────────────────────────────────────────
# Not currently consumed by app/settings.py, but read by other tooling/scripts.
DATABASE_URL=postgresql://user:password@localhost:5432/openclaw
