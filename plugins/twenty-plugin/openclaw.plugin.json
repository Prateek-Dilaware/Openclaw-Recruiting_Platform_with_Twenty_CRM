  "toolMetadata": {
    "_default": {
      "configSignals": [
        {
          "rootPath": "plugins.entries.twenty-openclaw.config",
          "required": ["apiKey"]
        }
      ]
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Master switch — disables all Twenty tools when false"
      },
      "apiKey": {
        "type": "string",
        "description": "Twenty API key sent as `Authorization: Bearer <key>`. Supports ${ENV_VAR} substitution."
      },
      "serverUrl": {
        "type": "string",
        "description": "Twenty server base URL (no trailing slash). REQUIRED — the plugin has no default. Supports ${ENV_VAR} substitution."
      },
      "allowedWorkspaceIds": {
        "type": "array",
        "items": { "type": "string" },
        "default": [],
        "description": "Whitelist of Twenty workspace UUIDs the plugin is allowed to operate on. Any tool call referencing a workspace outside this list is rejected before any HTTP request is made."
      },
      "defaultWorkspaceId": {
        "type": "string",
        "description": "Default Twenty workspace UUID injected when a tool does not explicitly provide one. Must be present in `allowedWorkspaceIds`. Supports ${ENV_VAR} substitution."
      },
      "approvalRequired": {
        "type": "array",
        "items": { "type": "string" },
        "default": [
          "twenty_people_delete",
          "twenty_companies_delete",
          "twenty_opportunities_delete",
          "twenty_notes_delete",
          "twenty_tasks_delete",
          "twenty_dedup_auto_merge",
          "twenty_bulk_import_csv",
          "twenty_bulk_delete",
          "twenty_metadata_object_create",
          "twenty_metadata_object_update",
          "twenty_metadata_object_delete",
          "twenty_metadata_field_create",
          "twenty_metadata_field_update",
          "twenty_metadata_field_delete",
          "twenty_record_delete",
          "twenty_page_layout_destroy",
          "twenty_page_layout_reset_to_default",
          "twenty_page_layout_replace_with_tabs",
          "twenty_page_layout_tab_destroy",
          "twenty_page_layout_tab_reset_to_default",
          "twenty_page_layout_widget_destroy",
          "twenty_page_layout_widget_reset_to_default",
          "twenty_workflow_delete",
          "twenty_workflow_version_activate",
          "twenty_workflow_version_deactivate",
          "twenty_workflow_version_delete",
          "twenty_workflow_run",
          "twenty_view_destroy",
          "twenty_view_field_destroy",
          "twenty_view_field_group_destroy",
          "twenty_view_filter_destroy",
          "twenty_view_filter_group_destroy",
          "twenty_view_sort_destroy",
          "twenty_view_group_destroy",
          "twenty_list_columns_reset_default",
          "twenty_metadata_field_options_set",
          "twenty_metadata_field_settings_set",
          "twenty_metadata_field_default_set",
          "twenty_metadata_field_constraints_set",
          "twenty_metadata_field_relation_settings_set",
          "twenty_role_create",
          "twenty_role_update",
          "twenty_role_delete",
          "twenty_role_assign_workspace_member",
          "twenty_role_assign_agent",
          "twenty_role_revoke_agent",
          "twenty_role_assign_api_key",
          "twenty_role_object_permissions_upsert",
          "twenty_role_field_permissions_upsert",
          "twenty_role_permission_flags_upsert",
          "twenty_role_row_level_predicates_upsert",
          "twenty_workspace_run_migration",
          "requisition_set_status",
          "application_set_stage",
          "interview_set_status",
          "evaluation_finalize",
          "offer_set_status"
        ],
        "description": "Tool names that trigger an approval prompt via the `before_tool_call` hook before being executed. Defaults to every destructive operation and recruiting lifecycle setter."
      },
      "readOnly": {
        "type": "boolean",
        "default": false,
        "description": "When true, blocks every write/delete operation at the plugin level regardless of approval state."
      },
      "logLevel": {
        "type": "string",
        "enum": ["debug", "info", "warn", "error"],
        "default": "info",
        "description": "Plugin log verbosity. `debug` includes request bodies (be mindful of PII)."
      },
      "allowedImportPaths": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["/home/node/.openclaw/", "/tmp/"],
        "description": "Whitelist of directories `twenty_bulk_import_csv` is allowed to read from. The supplied path is canonicalised (path.resolve) before the prefix check, so `../` traversal is blocked. An EXPLICIT empty array disables CSV import entirely."
      }
    },
    "required": ["serverUrl"]
  },
  "uiHints": {
    "enabled": {
      "label": "Enable Twenty tools",
      "help": "Master switch — turn off to fully disable all twenty_* tools without uninstalling"
    },
    "apiKey": {
      "label": "Twenty API Key",
      "placeholder": "${TWENTY_API_KEY}",
      "sensitive": true,
      "help": "Twenty REST API key. Sent as `Authorization: Bearer <key>`."
    },
    "serverUrl": {
      "label": "Twenty Server URL",
      "placeholder": "https://crm.example.com",
      "help": "Base URL of the Twenty server (no trailing slash)."
    },
    "allowedWorkspaceIds": {
      "label": "Allowed Workspace IDs",
      "help": "Whitelist of Twenty workspace UUIDs. The plugin refuses to call any workspace outside this list."
    },
    "defaultWorkspaceId": {
      "label": "Default Workspace ID",
      "placeholder": "${TWENTY_WORKSPACE_ID}",
      "help": "Workspace UUID used when a tool does not specify one. Must appear in allowedWorkspaceIds."
    },
    "approvalRequired": {
      "label": "Tools requiring approval",
      "advanced": true,
      "help": "Tool names that trigger a `before_tool_call` approval prompt. Defaults cover every destructive operation."
    },
    "readOnly": {
      "label": "Read-only mode",
      "advanced": true,
      "help": "Block every write/delete at the plugin level. Useful for safe experimentation."
    },
    "logLevel": {
      "label": "Log level",
      "advanced": true,
      "help": "info (default), debug includes request bodies"
    },
    "allowedImportPaths": {
      "label": "Allowed CSV import paths",
      "advanced": true,
      "help": "Directories twenty_bulk_import_csv is allowed to read from. Paths are canonicalised before the check (defeats `../` traversal). Default: /home/node/.openclaw/ and /tmp/."
    }
  }
}
