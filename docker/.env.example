# ─── Openclaw Recruiting Platform — Docker Environment Template ──────────────
#
# Copy this file to docker/.env and fill in the values.
# This file is read by docker-compose.dev.yml and applies to infrastructure
# services (Twenty CRM, PostgreSQL, Redis, OpenClaw gateway).
#
# Backend-specific and LLM/ElevenLabs credentials belong in backend/.env.
# Frontend variables belong in frontend/.env.
#
# NEVER commit the real docker/.env with secrets to git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Twenty CRM Settings ─────────────────────────────────────────────────────

# Docker image tag for Twenty CRM (use 'latest' or pin, e.g. '0.32.0').
TWENTY_TAG=latest

# PostgreSQL credentials (used by Twenty CRM and its Postgres container).
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=your_secure_password_here

# Public URL where Twenty CRM will be accessible from the host machine.
TWENTY_SERVER_URL=http://localhost:3000

# Encryption key — generate with: openssl rand -hex 32
# REQUIRED: must be a 64-character hex string.
TWENTY_ENCRYPTION_KEY=replace_with_a_64_character_hex_string_generated_by_openssl

# ─── OpenClaw Gateway ────────────────────────────────────────────────────────
# Token used to authenticate against the OpenClaw gateway control UI.
# IMPORTANT: paste this EXACT value into http://localhost:18789 the first time
# you onboard. It must also match OPENCLAW_API_KEY in backend/.env.
OPENCLAW_GATEWAY_TOKEN=your-secure-gateway-token

# ─── Not Configured Here ─────────────────────────────────────────────────────
# The following are intentionally NOT defined in docker/.env:
#   - TWENTY_API_KEY, OPENROUTER_API_KEY, GEMINI_API_KEY, OPENAI_API_KEY,
#     ELEVENLABS_*, USE_OPENCLAW, OPENCLAW_API_URL
#     → live in backend/.env (loaded via env_file: ../backend/.env)
#   - VITE_API_URL, VITE_APP_NAME
#     → live in frontend/.env (or as compose environment: overrides)
