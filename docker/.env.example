# ─── Openclaw Recruiting Platform — Environment Template ──────────────────────
#
# Copy this file to docker/.env and fill in the values.
# This file is used by docker-compose.dev.yml.
#
# NEVER commit the real .env file with secrets to git.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Twenty CRM Settings ──────────────────────────────────────────────────────

# Docker image tag for Twenty CRM (use 'latest' or pin to a specific version e.g. '0.32.0')
TWENTY_TAG=latest

# PostgreSQL credentials (used by Twenty CRM and its Postgres container)
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=your_secure_password_here

# Public URL where Twenty CRM will be accessible (change if deploying remotely)
TWENTY_SERVER_URL=http://localhost:3000

# Encryption keys — generate with: openssl rand -base64 32
# REQUIRED: Must be a 64-character hex string
TWENTY_ENCRYPTION_KEY=replace_with_a_64_character_hex_string_generated_by_openssl

# Optional legacy secret (only needed for instances that pre-date ENCRYPTION_KEY)
# TWENTY_APP_SECRET=

# ─── Backend Settings ─────────────────────────────────────────────────────────
# These are passed via backend/.env (loaded separately by the backend service).
# The TWENTY_API_URL is overridden inside docker-compose.dev.yml automatically
# to point to the twenty-server container, so you don't need to change it here.

# ─── Openclaw Settings ────────────────────────────────────────────────────────
# The token used to authenticate with the OpenClaw Gateway
OPENCLAW_GATEWAY_TOKEN=your-secure-gateway-token

# The API key used by OpenClaw to interact with Twenty CRM
# TWENTY_API_KEY=your-twenty-api-key
